{
  "name": "analytical-engine",
  "version": "0.0.1",
  "description": "Babbage's Analytic Engine emulator",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json",
    "./scripts/*": "./scripts/*",
    "./Library/*": "./Library/*"
  },
  "browser": {
    "./scripts/node-fileio.js": "./scripts/no-node-fileio.js"
  },
  "files": [
    "Library",
    "scripts",
    "analytical-engine",
    "index.js",
    "index.mjs",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "node --test"
  },
  "bin": {
    "analytical-engine": "./analytical-engine"
  },
  "author": "Alec Lownes and John Walker",
  "license": "ISC",
  "dependencies": {
    "big-integer": "^1.6.22",
    "yargs": "^17.7.2"
  },
  "devDependencies": {},
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cakenggt/analytical-engine.git"
  },
  "keywords": [
    "analytical-engine",
    "babbage"
  ],
  "bugs": {
    "url": "https://github.com/cakenggt/analytical-engine/issues"
  },
  "homepage": "https://github.com/cakenggt/analytical-engine#readme"
}
